# ========= Merch Miner ENV Template (PROD) =========
# Copy on server before deploy:
# cp .env.prod.template .env

# Optional helper for scripts/init-db.sh
SUPABASE_CONTAINER=supabase-db

# ========= App =========
COMPANY_NAME=Merch Miner
SECRET_KEY=set-a-strong-production-secret-key
DEBUG=False

# ========= Hosts / CORS =========
ALLOWED_HOSTS=miner.mariowinter.com,merch-miner.mariowinter.com
CSRF_TRUSTED_ORIGINS=https://miner.mariowinter.com,https://merch-miner.mariowinter.com
CORS_ALLOWED_ORIGINS=https://merch-miner.mariowinter.com

# ========= Frontend URLs (for email links) =========
FRONTEND_URL=https://merch-miner.mariowinter.com
FRONTEND_ACTIVATION_URL=https://merch-miner.mariowinter.com/activate
FRONTEND_CONFIRM_PASSWORD_URL=https://merch-miner.mariowinter.com/password-reset/confirm

# ========= Frontend (Vite) =========
# Source of truth for GHCR frontend image is GitHub Actions secret VITE_API_URL.
# This value is only used if you build frontend image manually on server.
VITE_API_URL=https://miner.mariowinter.com

# Cloud Manager — Google Drive (PROJ-9)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Cloud Manager — OneDrive (PROJ-9)
VITE_ONEDRIVE_CLIENT_ID=

# ========= Superuser (auto-created only if DJANGO_SUPERUSER_PASSWORD is set) =========
DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@example.com

# ========= Google OAuth2 =========
GOOGLE_CLIENT_ID=your-google-oauth2-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth2-client-secret

# ========= Database (Django, Supabase) =========
DB_HOST=supabase-db
DB_PORT=5432
DB_NAME=postgres
DB_USER=merch_miner_user
DB_PASSWORD=set-your-supabase-password
DB_SCHEMA=merch_miner

# ========= Redis =========
REDIS_HOST=redis
REDIS_LOCATION=redis://redis:6379/1
REDIS_PORT=6379
REDIS_DB=0

# ========= Email (SMTP) =========
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email_user
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@example.com
# Recipient for bug/feature reports submitted via the in-app modal
# (FIX-dashboard-bug-report-and-polish Item 1). Falls back to
# DEFAULT_FROM_EMAIL when unset.
FEEDBACK_RECIPIENT_EMAIL=mariowinter.sg@gmail.com

# ========= Integrations / Webhooks =========
N8N_WEBHOOK_URL=
N8N_CALLBACK_SECRET=
POLAR_WEBHOOK_SECRET=

# ========= Scraper (PROJ-16) =========
SCRAPEOPS_API_KEY=

# ========= Bulk ASIN Scrape (PROJ-25) =========
# Number of worker-scraper replicas. Each replica ~1-2 GB RAM under full Scrapy concurrency.
BACKEND_SCRAPER_WORKERS=5

# ========= Niche Research / LangGraph (PROJ-6) =========
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SEARXNG_BASE_URL=

# Model name (OpenRouter syntax) used for dashboard Changelog Widget
# translation. Default openai/gpt-4o-mini.
CHANGELOG_TRANSLATE_MODEL=openai/gpt-4o-mini

# ========= Vector Database / Embeddings (PROJ-15) =========
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ========= Deep Web Search — Vane + Crawl4ai (PROJ-17) =========
# Internal Docker network — services run inside localai-stack on the same host.
VANE_API_URL=http://vane:3000
CRAWL4AI_API_URL=http://crawl4ai:11235
VANE_DEFAULT_MODEL=gpt-4.1-mini
VANE_EMBEDDING_MODEL=text-embedding-3-small
# Keep false in prod until PROJ-15 vector backfill is complete.
VECTOR_DB_ENABLED=false

# ========= Langfuse Observability =========
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ========= AI Upscaler — Replicate (PROJ-27) =========
REPLICATE_API_TOKEN=
REPLICATE_WEBHOOK_SECRET=
REPLICATE_WEBHOOK_SECRET_PREVIOUS=
REPLICATE_WEBHOOK_URL=

