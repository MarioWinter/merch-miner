# ========= Merch Miner ENV Template (DEV) =========
# Copy for local development:
# cp .env.dev.template .env

# Local Postgres container (db service in docker-compose.override.yml)
POSTGRES_DB=merch_miner_dev
POSTGRES_USER=merch_miner_user
POSTGRES_PASSWORD=devpassword

# Optional helper for scripts/init-db.sh
SUPABASE_CONTAINER=supabase-db

# ========= App =========
COMPANY_NAME=Merch Miner
SECRET_KEY=generate-a-new-secret-key-here
DEBUG=True

# ========= Hosts / CORS =========
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========= Frontend URLs (for email links) =========
FRONTEND_URL=http://localhost:5173
FRONTEND_ACTIVATION_URL=http://localhost:5173/activate
FRONTEND_CONFIRM_PASSWORD_URL=http://localhost:5173/password-reset/confirm

# ========= Frontend (Vite) =========
# API base URL used in frontend-ui/src/services/authService.ts
VITE_API_URL=http://localhost:8000

# Cloud Manager — Google Drive (PROJ-9)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Cloud Manager — OneDrive (PROJ-9)
VITE_ONEDRIVE_CLIENT_ID=

# ========= Superuser (auto-created only if DJANGO_SUPERUSER_PASSWORD is set) =========
DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@example.com

# ========= Google OAuth2 =========
GOOGLE_CLIENT_ID=your-google-oauth2-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth2-client-secret

# ========= Database (Django, Dev) =========
DB_HOST=db
DB_PORT=5432
DB_NAME=merch_miner_dev
DB_USER=merch_miner_user
DB_PASSWORD=devpassword
DB_SCHEMA=public

# ========= Redis =========
REDIS_HOST=redis
REDIS_LOCATION=redis://redis:6379/1
REDIS_PORT=6379
REDIS_DB=0

# ========= Email (SMTP) =========
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email_user
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@example.com

# ========= Integrations / Webhooks =========
N8N_WEBHOOK_URL=
N8N_CALLBACK_SECRET=
POLAR_WEBHOOK_SECRET=

# ========= Scraper (PROJ-16) =========
SCRAPEOPS_API_KEY=
SCRAPY_CONCURRENT_REQUESTS=1

# ========= Bulk ASIN Scrape (PROJ-25) =========
# Number of worker-scraper replicas. Each replica ~1-2 GB RAM under full Scrapy concurrency.
BACKEND_SCRAPER_WORKERS=5

# ========= Selector Health Check (PROJ-23) =========
# Max HTML snapshots kept per (asin, marketplace). Default 12 (~3 months @ weekly).
SELECTOR_HEALTH_CHECK_RETENTION=12
# Cron expression for the weekly health-check runner. UTC. Default: Mon 04:00.
SELECTOR_HEALTH_CHECK_SCHEDULE_CRON=0 4 * * 1

# ========= Niche Research / LangGraph (PROJ-6) =========
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SEARXNG_BASE_URL=http://searxng:8080

# ========= Vector Database / Embeddings (PROJ-15) =========
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ========= Langfuse Observability =========
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ========= JungleScout (PROJ-10 Keyword Research) =========
JUNGLESCOUT_API_KEY_NAME=
JUNGLESCOUT_API_KEY=
JUNGLESCOUT_DEFAULT_MARKETPLACE=us

# ========= Deep Web Search — Vane + Crawl4ai (PROJ-17) =========
# Local dev: SSH tunnel to prod. Services bound on prod host loopback:
#   vane     -> 127.0.0.1:3010   (host port 3000 is taken by langfuse-web)
#   crawl4ai -> 127.0.0.1:11235
# Tunnel: ssh -fN -L 3000:127.0.0.1:3010 -L 11235:127.0.0.1:11235 root@<prod>
VANE_API_URL=http://host.docker.internal:3000
CRAWL4AI_API_URL=http://host.docker.internal:11235
VANE_DEFAULT_MODEL=gpt-4.1-mini
VANE_EMBEDDING_MODEL=text-embedding-3-small
# Set to false until PROJ-15 (Vector DB) backfill complete in prod.
VECTOR_DB_ENABLED=true

# ========= OpenClaw Agent (PROJ-18) =========
OPENROUTER_AGENT_API_KEY=
AGENT_BUDGET_WARNING_THRESHOLD=
# Per-sub-agent timeout in seconds (EC-15). Default 600 (10 min). On TimeoutError
# the orchestrator pauses the workflow and asks the user how to proceed.
AGENT_SUBAGENT_TIMEOUT_SEC=600

# ========= Publish / Cloud Import (PROJ-11) =========
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# ========= AI Upscaler — Replicate (PROJ-27) =========
# Server-side API token used by `worker-design` to fire Replicate predictions.
# Never exposed to frontend. Get via https://replicate.com/account/api-tokens.
REPLICATE_API_TOKEN=
# Webhook signing secret. One-time fetch:
#   curl -s -H "Authorization: Bearer $REPLICATE_API_TOKEN" \
#        https://api.replicate.com/v1/webhooks/default/secret
# Returns {"key":"whsec_..."}; store the FULL value (incl. whsec_ prefix).
# SDK strips the prefix internally during validate().
REPLICATE_WEBHOOK_SECRET=
# Optional rotation grace: when rotating REPLICATE_WEBHOOK_SECRET, copy the
# previous value here for ~1h so in-flight predictions still validate. Then
# clear this env var. EC-9 in PROJ-27 spec.
REPLICATE_WEBHOOK_SECRET_PREVIOUS=
# Public URL the worker passes to Replicate as the webhook callback. Must be
# reachable from the internet. Defaults to BACKEND_URL + /api/upscale/callback/.
# Override to support staging/local-tunnel setups.
REPLICATE_WEBHOOK_URL=

# ========= PROJ-31 Pre-auth registration toggle =========
# All other feature gating is runtime via /api/auth/me/ entitlements
# (see django-app/core/entitlements.py). Registration is the ONE exception
# because it fires BEFORE login — no authenticated user → no entitlement
# resolution possible. Only the literal string 'true' enables it.
VITE_ENABLE_REGISTRATION=false

# Google OAuth login button on /login. Same pre-auth rationale as registration:
# can't entitlement-gate before login. Off in public-facing prod; flip per env.
VITE_ENABLE_GOOGLE_LOGIN=false

