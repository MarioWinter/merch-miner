:80 {
    encode gzip

    handle /static/* {
        root * /srv
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    handle /media/* {
        root * /srv
        file_server
        header Cache-Control "public, max-age=86400"
    }

    handle {
        reverse_proxy web:8000
    }
}
