:80 {
	encode gzip

	handle /static/* {
		root * /srv
		file_server
		header Cache-Control "public, max-age=31536000, immutable"
	}

	handle /media/* {
		root * /srv
		file_server
		header Cache-Control "public, max-age=86400"
	}

	handle /api/* {
		reverse_proxy web:8000
	}

	handle /admin/* {
		reverse_proxy web:8000
	}

	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}
}
