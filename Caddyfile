miner.mariowinter.com {
    handle /static/* {
        root * /srv
        file_server
    }
    handle /media/* {
        root * /srv
        file_server
    }
    handle /api/* {
        reverse_proxy web:8000
    }
    handle /admin/* {
        reverse_proxy web:8000
    }
    handle {
        reverse_proxy frontend:80
    }
}
